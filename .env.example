# =============================================================
# cultivOS Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your actual values
# NEVER commit the .env file to git!
# =============================================================

# Database
DB_URL=sqlite:///cultivos.db

# JWT Authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-random-32-char-string

# WhatsApp Business API
# WHATSAPP_API_TOKEN=your_token_here
# WHATSAPP_PHONE_ID=your_phone_id_here

# Weather API (free at openweathermap.org)
# OPENWEATHER_API_KEY=your_key_here

# S3-compatible storage for drone imagery
# S3_BUCKET=cultivos-imagery
# S3_ENDPOINT=https://your-s3-endpoint
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret

# Optional — AI-powered recommendations
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Redis (optional, runs without it)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO

# CORS (set your domain in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
